rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users: { name, nameLower, pinHash, role, createdAt }
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['name', 'nameLower', 'pinHash', 'role'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 30
        && request.resource.data.pinHash is string
        && request.resource.data.role in ['admin', 'member']
        && (!('photo' in request.resource.data)
            || (request.resource.data.photo is string
                && request.resource.data.photo.size() < 120000));
      // Only role (admin promote/demote) and photo may ever change;
      // name and PIN stay immutable. Accounts can't be deleted from the app.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['role', 'photo'])
        && request.resource.data.role in ['admin', 'member']
        && (!('photo' in request.resource.data)
            || (request.resource.data.photo is string
                && request.resource.data.photo.size() < 120000));
      allow delete: if false;
    }

    // sessions: { location, time, maxPlayers, inVotes, outVotes, ... }
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.location is string
        && request.resource.data.time is timestamp
        && request.resource.data.maxPlayers is int
        && request.resource.data.maxPlayers >= 2
        && request.resource.data.inVotes is list
        && request.resource.data.outVotes is list
        && (!('totalFee' in request.resource.data)
            || (request.resource.data.totalFee is number
                && request.resource.data.totalFee >= 0));
      // Votes/guests change freely within the cap; core fields (location,
      // time, cap, fee — admin edits) must keep valid types. Players + guests
      // together may never exceed the (possibly updated) cap.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['inVotes', 'outVotes', 'guests', 'payments',
                       'location', 'time', 'maxPlayers', 'totalFee'])
        && (!('payments' in request.resource.data)
            || request.resource.data.payments is map)
        && request.resource.data.location is string
        && request.resource.data.location.size() > 0
        && request.resource.data.time is timestamp
        && request.resource.data.maxPlayers is int
        && request.resource.data.maxPlayers >= 2
        && (!('totalFee' in request.resource.data)
            || (request.resource.data.totalFee is number
                && request.resource.data.totalFee >= 0))
        && (request.resource.data.inVotes.size()
            + ('guests' in request.resource.data ? request.resource.data.guests.size() : 0))
           <= request.resource.data.maxPlayers;
      allow delete: if request.auth != null;
    }

    // tournament/season4: admin-edited info (date, location, fees, bkash)
    match /tournament/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (!('fees' in request.resource.data) || request.resource.data.fees is map);
    }

    // Season 4 player registrations
    match /tournamentRegs/{regId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 40
        && request.resource.data.position in ['Goalkeeper', 'Defender', 'Midfielder', 'Forward']
        && request.resource.data.batch in ['b2021', 'b2022', 'b2023', 'b2024']
        && request.resource.data.txn is string
        && request.resource.data.txn.size() >= 4
        && request.resource.data.photo is string
        && request.resource.data.photo.size() < 120000;
      // admin edits/removals (admin gate is app-level, consistent with sessions)
      allow update: if request.auth != null
        && request.resource.data.position in ['Goalkeeper', 'Defender', 'Midfielder', 'Forward']
        && request.resource.data.batch in ['b2021', 'b2022', 'b2023', 'b2024']
        && (!('soldFor' in request.resource.data)
            || request.resource.data.soldFor == null
            || (request.resource.data.soldFor is number
                && request.resource.data.soldFor >= 0));
      allow delete: if request.auth != null;
    }

    // Season 4 league table teams
    match /tournamentTeams/{teamId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.wins is int
        && request.resource.data.draws is int
        && request.resource.data.losses is int
        && request.resource.data.gd is int
        && request.resource.data.wins >= 0
        && request.resource.data.draws >= 0
        && request.resource.data.losses >= 0
        && (!('credits' in request.resource.data)
            || (request.resource.data.credits is number
                && request.resource.data.credits >= 0));
      allow delete: if request.auth != null;
    }
  }
}
